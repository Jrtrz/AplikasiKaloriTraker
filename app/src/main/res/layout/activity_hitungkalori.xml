<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hitung Kalori Makanan"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2E7D32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"
            android:text="Pilih makanan untuk melihat informasi nutrisi"
            android:textSize="16sp"
            android:textColor="#666666" />

        <!-- Image Makanan -->
        <ImageView
            android:id="@+id/imgMakanan"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="20dp"
            android:scaleType="centerInside"
            android:src="@mipmap/ic_launcher_round"
            android:background="#E0E0E0"
            android:contentDescription="Gambar Makanan" />

        <!-- Spinner -->
        <Spinner
            android:id="@+id/spMakanan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Tombol Hitung -->
        <Button
            android:id="@+id/btnHitung"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="Tampilkan Nutrisi"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF" />

        <!-- Tombol Simpan -->
        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:text="Simpan ke Riwayat"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

        <!-- Hasil -->
        <TextView
            android:id="@+id/txtKalori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Kalori : -"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtProtein"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Protein : -"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtLemak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Lemak : -"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtKarbo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Karbohidrat : -"
            android:textSize="18sp" />

        <!-- Tombol Kembali -->
        <Button
            android:id="@+id/btnKembali"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:text="Kembali"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</ScrollView>